# ── LLM & AI ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...

# ── Vector DB ─────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=                          # set a strong key in production (openssl rand -hex 32)
QDRANT_COLLECTION=imocha_kb_v2

# ── PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://imocha:imochapassword@postgres:5432/imocha_hub
POSTGRES_USER=imocha
POSTGRES_PASSWORD=<strong-password>
POSTGRES_DB=imocha_hub

# ── File Storage ──────────────────────────────────────────
STORAGE_BACKEND=local                # local | s3
LOCAL_UPLOAD_DIR=./uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=imocha-hub-docs

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=<min-32-char-random-string: openssl rand -hex 32>
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ── Admin seed ────────────────────────────────────────────
ADMIN_EMAIL=admin@yourcompany.io
ADMIN_PASSWORD=<strong-password>
ADMIN_NAME=Platform Admin

# ── App ───────────────────────────────────────────────────
ENVIRONMENT=development              # development | production
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=25
CRAG_RELEVANCE_THRESHOLD=0.65
RETRIEVAL_TOP_K=20
RERANK_TOP_N=8

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
