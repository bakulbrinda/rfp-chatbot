# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ── Admin Seed ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=ChangeMe@Strong2026!
ADMIN_NAME=Platform Admin

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=imocha
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=imocha_hub
DATABASE_URL=postgresql+asyncpg://imocha:change-me-strong-db-password@postgres:5432/imocha_hub

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=imocha_kb

# ── External AI APIs ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...

# ── Storage ───────────────────────────────────────────────────────────────────
LOCAL_UPLOAD_DIR=/app/uploads
# AWS S3 (optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=imocha-kb-docs

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://yourdomain.com
